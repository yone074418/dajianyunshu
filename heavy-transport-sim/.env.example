# Supabase Configuration
# Copy this file to .env.local and fill in your values.
# .env.example can be committed to Git.
# .env.local must NEVER be committed — it contains your secrets.
#
# VITE_SUPABASE_URL: Your Supabase project URL (e.g. https://xxxx.supabase.co)
# VITE_SUPABASE_ANON_KEY: Your Supabase anonymous/public key
#
# IMPORTANT:
# - Only use the anon key in frontend code. It is safe to expose in the browser.
# - NEVER put a service role key in this file or any frontend code.
# - A service role key bypasses Row Level Security and must stay server-side only.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
